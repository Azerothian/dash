{
  "name": "dash",
  "version": "0.1.0",
  "description": "Cross-Platform Monitoring Dashboard",
  "main": "./out/main/index.js",
  "author": "Dash",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "typecheck": "pnpm typecheck:main && pnpm typecheck:renderer",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "package:win": "electron-builder --win"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@tanstack/react-query": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "clsx": "^2.1.0",
    "duckdb": "^1.2.0",
    "ejs": "^3.1.0",
    "electron-updater": "^6.0.0",
    "gridstack": "^10.0.0",
    "jsonpath-plus": "^10.0.0",
    "lucide-react": "^0.468.0",
    "node-schedule": "^2.1.0",
    "nodemailer": "^6.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "react-virtuoso": "^4.0.0",
    "recharts": "^2.15.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "tailwind-merge": "^2.6.0",
    "teen_process": "^2.0.0",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/ejs": "^3.1.0",
    "@types/node": "^22.0.0",
    "@types/node-schedule": "^2.1.0",
    "@types/nodemailer": "^6.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
